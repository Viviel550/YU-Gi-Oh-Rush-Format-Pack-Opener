---
// You can pass a title prop dynamically later if you wish
const { title = "YGO Deck & Pack Simulator" } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <!-- Importing a sharp, sci-fi/gaming font stack for headers -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700;900&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet">
    </head>
    <body>
        <div class="arena-wrapper">
            <main class="content-container">
                <slot />
            </main>
        </div>
    </body>
</html>

<style is:global>
    /* Global design tokens based on YGO signature color schemes */
    :root {
        --bg-void: #0a0a0f;           /* Deep dark background */
        --bg-arena: #12121a;          /* Playmat/Surface color */
        --bg-card-slot: #1c1c24;      /* Individual item slots */
        
        --millennium-gold: #f5b914;   /* Iconic puzzle gold */
        --gold-glow: rgba(245, 185, 20, 0.25);
        
        --cyber-blue: #00f0ff;        /* Link/Synchro neon blue */
        --spell-purple: #5b21b6;      /* Dark Magician violet */
        
        --text-primary: #f3f4f6;
        --text-muted: #9ca3af;
        
        --font-display: 'Orbitron', sans-serif;
        --font-body: 'Rajdhani', sans-serif;
    }

    html,
    body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        background-color: var(--bg-void);
        color: var(--text-primary);
        font-family: var(--font-body);
        font-size: 18px;
        letter-spacing: 0.05em;
        overflow-x: hidden;
    }

    /* Custom Dueling Scrollbar */
    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: var(--bg-void);
    }
    ::-webkit-scrollbar-thumb {
        background: var(--bg-card-slot);
        border: 2px solid var(--bg-void);
        border-radius: 4px;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: var(--millennium-gold);
    }
</style>

<style>
    /* Layout Container Structure */
    .arena-wrapper {
        min-height: 100vh;
        width: 100%;
        /* Futuristic, subtle angled background matrix */
        background: 
            radial-gradient(circle at 50% 0%, rgba(91, 33, 182, 0.15) 0%, transparent 50%),
            linear-gradient(var(--bg-void) 0%, #111118 100%);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 2rem 1rem;
        box-sizing: border-box;
    }

    .content-container {
        width: 100%;
        max-width: 1400px; /* Gives the grid room to breath like a real playmat */
        margin: 0 auto;
        animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>